generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────
model User {
  id                      String                @id @default(uuid())
  fullName                String                @map("full_name")
  username                String?               @unique @map("username")
  email                   String                @unique @map("email")
  phoneNumber             String?               @map("phone_number")
  password                String                @map("password")
  isVerified              Boolean               @default(false) @map("is_verified")
  verificationToken       String?               @map("verification_token")
  verificationTokenExpiry DateTime?             @map("verification_token_expiry")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  avatarUrl               String?               @map("avatar_url")
  bio                     String?               @map("bio")
  financialGoals          String?               @map("financial_goals")
  monthlyIncomeTarget     Float?                @map("monthly_income_target")

  accounts            Account[]
  incomes             Income[]
  budgetCategories    BudgetCategory[]
  budgetItems         BudgetItem[]
  expenses            Expense[]
  transfers           Transfer[]
  notifications       Notification[]
}

// ─────────────────────────────────────────────
// ACCOUNTS / SOURCES
// ─────────────────────────────────────────────
model Account {
  id               String   @id @default(uuid())
  userId           String
  accountName      String
  accountType      String   // "CASHFLOW" | "SAVINGS"
  providerName     String   // e.g. "BCA", "OVO", "Cash"
  providerCategory String   // "BANK" | "E_WALLET" | "CASH" | "OTHER"
  currentBalance   Float    @default(0)
  targetAmount     Float?
  color            String?  // hex color for UI
  icon             String?  // emoji or url
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user                     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes                  Income[]
  budgetItemsAsSource      BudgetItem[]         @relation("SourceBudgetItems")
  budgetItemsAsDestination BudgetItem[]         @relation("DestinationBudgetItems")
  expenses                 Expense[]
  outgoingTransfers        Transfer[]           @relation("OutgoingTransfers")
  incomingTransfers        Transfer[]           @relation("IncomingTransfers")

  @@index([userId])
}

// ─────────────────────────────────────────────
// INCOMES
// ─────────────────────────────────────────────
model Income {
  id              String   @id @default(uuid())
  userId          String
  accountId       String
  amount          Float
  incomeType      String   // "SALARY" | "FREELANCE" | "BUSINESS" | "INVESTMENT" | "OTHER"
  description     String?
  transactionDate DateTime
  createdAt       DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
}

// ─────────────────────────────────────────────
// BUDGET CATEGORIES (Needs / Wants / Savings)
// ─────────────────────────────────────────────
model BudgetCategory {
  id           String       @id @default(uuid())
  userId       String
  categoryName String       // "Needs" | "Wants" | "Savings"
  createdAt    DateTime     @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgetItems BudgetItem[]
  expenses    Expense[]

  @@index([userId])
}

// ─────────────────────────────────────────────
// BUDGET ITEMS (e.g. "Coffee Rp500.000 / Wants / OVO")
// ─────────────────────────────────────────────
model BudgetItem {
  id              String   @id @default(uuid())
  userId          String
  categoryId      String
  sourceAccountId String?  // account money comes FROM (e.g., BNI - income)
  accountId       String?  // account money goes TO (destination)
  itemName        String
  allocatedAmount Float
  usedAmount      Float    @default(0)
  remainingAmount Float    @default(0)
  color           String?
  period          String?  // "YYYY-MM" for monthly tracking
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  sourceAccount Account?       @relation("SourceBudgetItems", fields: [sourceAccountId], references: [id])
  account       Account?       @relation("DestinationBudgetItems", fields: [accountId], references: [id])
  expenses      Expense[]

  @@index([userId])
  @@index([categoryId])
  @@index([sourceAccountId])
  @@index([accountId])
}

// ─────────────────────────────────────────────
// EXPENSES
// ─────────────────────────────────────────────
model Expense {
  id              String   @id @default(uuid())
  userId          String
  accountId       String
  budgetItemId    String?
  categoryId      String?
  amount          Float
  description     String?
  transactionDate DateTime
  notes           String?
  createdAt       DateTime @default(now())

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  account    Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  budgetItem BudgetItem?     @relation(fields: [budgetItemId], references: [id])
  category   BudgetCategory? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([accountId])
  @@index([budgetItemId])
  @@index([categoryId])
}

// ─────────────────────────────────────────────
// TRANSFERS (Transfer: Cashflow <-> Savings)
// ─────────────────────────────────────────────
model Transfer {
  id              String   @id @default(uuid())
  userId          String
  fromAccountId   String
  toAccountId     String
  amount          Float
  transferType    String   // "ADD_FUNDS" | "WITHDRAW"
  notes           String?
  transactionDate DateTime @default(now())
  createdAt       DateTime @default(now())

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount Account @relation("OutgoingTransfers", fields: [fromAccountId], references: [id], onDelete: Cascade)
  toAccount   Account @relation("IncomingTransfers", fields: [toAccountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fromAccountId])
  @@index([toAccountId])
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // "BUDGET_ALERT" | "SAVINGS_MILESTONE" | "BALANCE_LOW" | "AI_INSIGHT" | "SYSTEM"
  title     String
  message   String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
